generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeatherRecord {
  id          String   @id @default(uuid())
  city        String
  temp        Float
  description String
  humidity    Int
  windSpeed   Float
  icon        String
  createdAt   DateTime @default(now())
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  timestamp DateTime @default(now())
}
